# Copy this file to `.env` and fill in values from Supabase → Project Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Storage bucket name for exercise videos (create as Public in Supabase Storage)
EXPO_PUBLIC_SUPABASE_VIDEO_BUCKET=exercise-videos
